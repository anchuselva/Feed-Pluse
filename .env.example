# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/feedpulse

# Google Gemini API key for the generative language API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# JWT secret used for admin authentication
JWT_SECRET=change_this_to_a_secure_value

# Admin credentials
ADMIN_EMAIL=admin@feedpulse.com
ADMIN_PASSWORD=admin123

# API server port
PORT=4000
